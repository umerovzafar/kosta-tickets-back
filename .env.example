GATEWAY_PORT=1234
GATEWAY_BASE_URL=http://localhost:1234

# ========== Редиректы: что менять при смене домена (и в Entra ID те же URL) ==========
# Фронт: https://tickets.kostalegal.com  |  API (gateway): https://ticketsback.kostalegal.com
# OAuth redirect_uri всегда на API (ticketsback), не на фронте.
#
# 1) Вход через Azure AD (callback → gateway → auth; в Entra ID добавить этот же URL):
AZURE_REDIRECT_URI=http://localhost:1234/api/v1/auth/azure/callback
#    Production: AZURE_REDIRECT_URI=https://ticketsback.kostalegal.com/api/v1/auth/azure/callback
#
# 2) Календарь Outlook (callback → gateway → todos; в Entra ID — тот же URL):
MICROSOFT_REDIRECT_URI=http://localhost:1234/api/v1/todos/calendar/callback
#    Production: MICROSOFT_REDIRECT_URI=https://ticketsback.kostalegal.com/api/v1/todos/calendar/callback
#
# 3) После OAuth календаря Microsoft редиректит сюда (SPA на фронт-домене, ?calendar=connected|error):
CALENDAR_CONNECTED_REDIRECT_URL=http://localhost:5173
#    Production: CALENDAR_CONNECTED_REDIRECT_URL=https://tickets.kostalegal.com/
#
# 4) FRONTEND_URL — origin SPA (CORS). GATEWAY_BASE_URL — публичный URL API (ws, ссылки).
FRONTEND_URL=http://localhost:5173
#    Production: FRONTEND_URL=https://tickets.kostalegal.com
#    Production: GATEWAY_BASE_URL=https://ticketsback.kostalegal.com
#
# В docker-compose auth получает AUTH_REDIRECT_URI из AZURE_REDIRECT_URI — меняйте AZURE_REDIRECT_URI.

# URL микросервисов для gateway (обязательно согласовать с тем, ГДЕ запущен gateway).
#
# Все сервисы через docker compose — имена сервисов и внутренние порты:
AUTH_SERVICE_URL=http://auth:1236
TICKETS_SERVICE_URL=http://tickets:1235
NOTIFICATIONS_SERVICE_URL=http://notifications:1237
INVENTORY_SERVICE_URL=http://inventory:1238
TODOS_SERVICE_URL=http://todos:1240
TIME_TRACKING_SERVICE_URL=http://time_tracking:1241
EXPENSES_SERVICE_URL=http://expenses:1242
# Опционально: лимит суммы заявки (UZS); выше — ошибка при submit
# EXPENSE_AMOUNT_LIMIT_UZS=
ATTENDANCE_SERVICE_URL=http://attendance:1239
#
# Gateway запущен на хосте (uvicorn локально), а auth/attendance — тоже на хосте с портами из Dockerfile:
# AUTH_SERVICE_URL=http://127.0.0.1:1236
# ATTENDANCE_SERVICE_URL=http://127.0.0.1:1239
# EXPENSES_SERVICE_URL=http://127.0.0.1:1242
#
# Только gateway в Docker, остальные процессы на Windows/Mac (Docker Desktop):
# AUTH_SERVICE_URL=http://host.docker.internal:1236
# ATTENDANCE_SERVICE_URL=http://host.docker.internal:1239
# EXPENSES_SERVICE_URL=http://host.docker.internal:1242
# Hikvision: IP камер (одна — HIKVISION_DEVICE_IP, несколько — HIKVISION_DEVICE_IPS через запятую)
HIKVISION_DEVICE_IP=
HIKVISION_DEVICE_IPS=
HIKVISION_DEVICE_PORT=80
HIKVISION_DEVICE_USER=admin
HIKVISION_DEVICE_PASSWORD=
HIKVISION_REQUEST_TIMEOUT=60
# IP камер для gateway (защита от SSRF — должен совпадать с HIKVISION_DEVICE_IP(S))
ATTENDANCE_HIKVISION_ALLOWED_IPS=
# FRONTEND_URL см. блок «Редиректы» выше
ADMIN_FRONTEND_URL=http://localhost:8080
# Если «Bind for 0.0.0.0:8080 failed: port is already allocated» — смените порт (например 8081).
ADMIN_PANEL_PORT=8080
MEDIA_PATH=/app/media

TELEGRAM_BOT_TOKEN=

AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI см. блок «Редиректы» выше
# Обязательно для production: задайте надёжный секрет
JWT_SECRET=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

ADMIN_USERNAME=admin
# Локальный вход в админ-панель: до первичной настройки — пара логин/пароль из env.
# После POST /auth/admin-bootstrap пароль хранится в БД; ADMIN_PASSWORD можно не задавать.
ADMIN_PASSWORD=
# Одноразовая первичная настройка на сервере: сгенерировать логин/пароль и записать в БД.
# Вызов: POST /api/v1/auth/admin/bootstrap с JSON {"secret":"<тот же секрет>"}. Потом секрет убрать из .env.
# ADMIN_BOOTSTRAP_SECRET=

# CALENDAR_CONNECTED_REDIRECT_URL и MICROSOFT_REDIRECT_URI см. блок «Редиректы» выше
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
