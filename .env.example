# Скопируйте в .env и заполните значения. Файл .env в .gitignore и не попадает в репозиторий.
#
# === Базы данных ===
# kosta_users (gateway + auth)
USERS_DB_USER=gateway
USERS_DB_PASSWORD=123456
USERS_DB_NAME=kosta_users

# kosta_tickets
TICKETS_DB_USER=tickets
TICKETS_DB_PASSWORD=
TICKETS_DB_NAME=kosta_tickets

# kosta_notifications
NOTIFICATIONS_DB_USER=notifications
NOTIFICATIONS_DB_PASSWORD=
NOTIFICATIONS_DB_NAME=kosta_notifications

# kosta_inventory
INVENTORY_DB_USER=inventory
INVENTORY_DB_PASSWORD=
INVENTORY_DB_NAME=kosta_inventory

# kosta_attendance
ATTENDANCE_DB_USER=attendance
ATTENDANCE_DB_PASSWORD=
ATTENDANCE_DB_NAME=kosta_attendance

# kosta_todos
TODOS_DB_USER=todos
TODOS_DB_PASSWORD=
TODOS_DB_NAME=kosta_todos

# kosta_time_tracking
TIME_TRACKING_DB_USER=time_tracking
TIME_TRACKING_DB_PASSWORD=
TIME_TRACKING_DB_NAME=kosta_time_tracking

# URL подключения (для docker: хост users_db / tickets_db / notifications_db; для локального запуска: localhost)
# Пароли должны совпадать с USERS_DB_PASSWORD / TICKETS_DB_PASSWORD / NOTIFICATIONS_DB_PASSWORD
GATEWAY_DATABASE_URL=postgresql://gateway:YOUR_USERS_PASSWORD@users_db:5432/kosta_users
AUTH_DATABASE_URL=postgresql://gateway:YOUR_USERS_PASSWORD@users_db:5432/kosta_users
TICKETS_DATABASE_URL=postgresql://tickets:YOUR_TICKETS_PASSWORD@tickets_db:5432/kosta_tickets
NOTIFICATIONS_DATABASE_URL=postgresql://notifications:YOUR_NOTIFICATIONS_PASSWORD@notifications_db:5432/kosta_notifications
INVENTORY_DATABASE_URL=postgresql://inventory:YOUR_INVENTORY_PASSWORD@inventory_db:5432/kosta_inventory
ATTENDANCE_DATABASE_URL=postgresql://attendance:YOUR_ATTENDANCE_PASSWORD@attendance_db:5432/kosta_attendance
TODOS_DATABASE_URL=postgresql://todos:YOUR_TODOS_PASSWORD@todos_db:5432/kosta_todos
TIME_TRACKING_DATABASE_URL=postgresql://time_tracking:YOUR_TIME_TRACKING_PASSWORD@time_tracking_db:5432/kosta_time_tracking

# === Шлюз ===
GATEWAY_PORT=1234
GATEWAY_BASE_URL=http://localhost:1234
AUTH_SERVICE_URL=http://auth:1236
TICKETS_SERVICE_URL=http://tickets:1235
NOTIFICATIONS_SERVICE_URL=http://notifications:1237
INVENTORY_SERVICE_URL=http://inventory:1238
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:8080
ADMIN_PANEL_PORT=8080
MEDIA_PATH=/app/media

# === Telegram Bot (уведомления) ===
# Токен от @BotFather (пока не обязателен)
TELEGRAM_BOT_TOKEN=

# === Auth (Azure AD + JWT) ===
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:1234/api/v1/auth/azure/callback
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# Вход в админ-панель по логину/паролю (без Microsoft)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
