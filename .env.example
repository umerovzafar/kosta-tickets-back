# Portainer / Docker Stack: рядом с compose может не быть .env — скопируйте нужные переменные в «Environment» стека
# (те же имена, что ниже: EXPENSE_SMTP_*, GATEWAY_BASE_URL, EXPENSE_EMAIL_ACTION_SECRET, EXPENSE_NOTIFY_*, FRONTEND_URL, …).

USERS_DB_USER=gateway
USERS_DB_PASSWORD=YOUR_USERS_DB_PASSWORD
USERS_DB_NAME=kosta_users

TICKETS_DB_USER=tickets
TICKETS_DB_PASSWORD=
TICKETS_DB_NAME=kosta_tickets

NOTIFICATIONS_DB_USER=notifications
NOTIFICATIONS_DB_PASSWORD=
NOTIFICATIONS_DB_NAME=kosta_notifications

INVENTORY_DB_USER=inventory
INVENTORY_DB_PASSWORD=
INVENTORY_DB_NAME=kosta_inventory

ATTENDANCE_DB_USER=attendance
ATTENDANCE_DB_PASSWORD=
ATTENDANCE_DB_NAME=kosta_attendance

TODOS_DB_USER=todos
TODOS_DB_PASSWORD=
TODOS_DB_NAME=kosta_todos

TIME_TRACKING_DB_USER=time_tracking
TIME_TRACKING_DB_PASSWORD=
TIME_TRACKING_DB_NAME=kosta_time_tracking

EXPENSES_DB_USER=expenses
EXPENSES_DB_PASSWORD=
EXPENSES_DB_NAME=kosta_expenses

# Проекты (отдельная БД; имя по умолчанию kosta_projects, как у остальных kosta_*).
# Нужно другое имя (например с дефисом) — задайте PROJECTS_DB_NAME и тот же хост в URL.
PROJECTS_DB_USER=projects
PROJECTS_DB_PASSWORD=YOUR_PROJECTS_PASSWORD
PROJECTS_DB_NAME=kosta_projects

# График отсутствий / отпусков (сервис vacation, порт 1244).
VACATION_DB_USER=vacation
VACATION_DB_PASSWORD=YOUR_VACATION_DB_PASSWORD
# Имя БД как у остальных kosta_*; при необходимости kosta-vacation — задайте VACATION_DB_NAME и URL с %2D вместо дефиса в пути.
VACATION_DB_NAME=kosta_vacation

GATEWAY_DATABASE_URL=postgresql://gateway:YOUR_USERS_PASSWORD@users_db:5432/kosta_users
AUTH_DATABASE_URL=postgresql://gateway:YOUR_USERS_PASSWORD@users_db:5432/kosta_users
TICKETS_DATABASE_URL=postgresql://tickets:YOUR_TICKETS_PASSWORD@tickets_db:5432/kosta_tickets
NOTIFICATIONS_DATABASE_URL=postgresql://notifications:YOUR_NOTIFICATIONS_PASSWORD@notifications_db:5432/kosta_notifications
INVENTORY_DATABASE_URL=postgresql://inventory:YOUR_INVENTORY_PASSWORD@inventory_db:5432/kosta_inventory
ATTENDANCE_DATABASE_URL=postgresql://attendance:YOUR_ATTENDANCE_PASSWORD@attendance_db:5432/kosta_attendance
TODOS_DATABASE_URL=postgresql://todos:YOUR_TODOS_PASSWORD@todos_db:5432/kosta_todos
TIME_TRACKING_DATABASE_URL=postgresql://time_tracking:YOUR_TIME_TRACKING_PASSWORD@time_tracking_db:5432/kosta_time_tracking
EXPENSES_DATABASE_URL=postgresql://expenses:YOUR_EXPENSES_PASSWORD@expenses_db:5432/kosta_expenses
PROJECTS_DATABASE_URL=postgresql://projects:YOUR_PROJECTS_PASSWORD@projects_db:5432/kosta_projects
VACATION_DATABASE_URL=postgresql://vacation:YOUR_VACATION_PASSWORD@vacation_db:5432/kosta_vacation

GATEWAY_PORT=1234
GATEWAY_BASE_URL=http://localhost:1234

# ========== Редиректы: что менять при смене домена (и в Entra ID те же URL) ==========
# Фронт: https://tickets.kostalegal.com  |  API (gateway): https://ticketsback.kostalegal.com
# OAuth redirect_uri всегда на API (ticketsback), не на фронте.
#
# 1) Вход через Azure AD (callback → gateway → auth; в Entra ID добавить этот же URL):
AZURE_REDIRECT_URI=http://localhost:1234/api/v1/auth/azure/callback
#    Production: AZURE_REDIRECT_URI=https://ticketsback.kostalegal.com/api/v1/auth/azure/callback
#
# 2) Календарь Outlook (callback → gateway → todos; в Entra ID — тот же URL):
MICROSOFT_REDIRECT_URI=http://localhost:1234/api/v1/todos/calendar/callback
#    Production: MICROSOFT_REDIRECT_URI=https://ticketsback.kostalegal.com/api/v1/todos/calendar/callback
#
# 3) После OAuth календаря Microsoft редиректит сюда (SPA на фронт-домене, ?calendar=connected|error):
CALENDAR_CONNECTED_REDIRECT_URL=http://localhost:5173
#    Production: CALENDAR_CONNECTED_REDIRECT_URL=https://tickets.kostalegal.com/
#
# 4) FRONTEND_URL — origin SPA (CORS). GATEWAY_BASE_URL — публичный URL API (ws, ссылки).
FRONTEND_URL=http://localhost:5173
#    Production: FRONTEND_URL=https://tickets.kostalegal.com
#    Production: GATEWAY_BASE_URL=https://ticketsback.kostalegal.com
#
# Локальная разработка SPA (Vite, репозиторий tickets-front): иначе fetch('/api/...') бьёт в :5173.
# Вариант A — прокси: см. tickets-back/vite.config.example.ts; цель по умолчанию http://127.0.0.1:1234 (gateway).
#   Ошибка ECONNREFUSED в Vite: gateway не запущен — из каталога tickets-back: docker compose up -d gateway todos todos_db
#   (для /api/v1/todos/calendar/* нужен сервис todos). Или VITE_PROXY_TARGET=https://ticketsback.kostalegal.com в .env.development фронта.
# Вариант B — без прокси: VITE_API_URL=http://127.0.0.1:1234 и полный URL в клиенте.
#
# В docker-compose auth получает AUTH_REDIRECT_URI из AZURE_REDIRECT_URI — меняйте AZURE_REDIRECT_URI.

# URL микросервисов для gateway (обязательно согласовать с тем, ГДЕ запущен gateway).
# В Portainer не оставляйте переменные пустыми (AUTH_SERVICE_URL=): gateway подставляет дефолты
# как в docker-compose, но лучше явно задать URL ниже.
#
# Все сервисы через docker compose — имена сервисов и внутренние порты:
AUTH_SERVICE_URL=http://auth:1236
TICKETS_SERVICE_URL=http://tickets:1235
NOTIFICATIONS_SERVICE_URL=http://notifications:1237
INVENTORY_SERVICE_URL=http://inventory:1238
# ВАЖНО: с хоста машины это не проверяйте curl'ом на localhost — gateway в Docker должен ходить на ИМЯ СЕРВИСА:
TODOS_SERVICE_URL=http://todos:1240
# Неверно для gateway в контейнере: http://127.0.0.1:1240 или http://localhost:1240 (это сам gateway, не todos → 503).
TIME_TRACKING_SERVICE_URL=http://time_tracking:1241
EXPENSES_SERVICE_URL=http://expenses:1242
# Общий справочник проектов (пока только /health внутри Docker-сети)
PROJECTS_SERVICE_URL=http://projects:1243
# 503 на GET /api/v1/expenses в проде: контейнер expenses должен быть в стеке, та же Docker-сеть,
# что и gateway; имя хоста = имя сервиса в compose (expenses). В другом стеке — external network
# или EXPENSES_SERVICE_URL=http://<хост>:1242 с пробросом порта.
# Опционально: лимит суммы заявки (UZS); выше — ошибка при submit
# EXPENSE_AMOUNT_LIMIT_UZS=
# Уровень логов контейнера expenses (docker compose): info | debug | warning | error
# EXPENSES_LOG_LEVEL=info
# Модератор может утверждать/отклонять свою заявку (true); false — запрет самомодерации
# EXPENSE_ALLOW_SELF_MODERATION=true
# Публичный URL gateway (как в браузере): ссылки «одним кликом» в письме — /api/v1/expenses/{id}/email-action?token=...
# GATEWAY_BASE_URL=https://ticketsback.kostalegal.com
# Секрет HMAC для токенов в письме (openssl rand -hex 32); без него + GATEWAY_BASE_URL в письме нет кнопок согласования
# EXPENSE_EMAIL_ACTION_SECRET=
# Срок жизни ссылки (сек), по умолчанию 7 дней
# EXPENSE_EMAIL_ACTION_TTL_SECONDS=604800
# Экран подтверждения перед утверждением/отклонением по ссылке (не SPA). false — одно нажатие = действие
# EXPENSE_EMAIL_ACTION_CONFIRM_STEP=true
#
# --- Почта: уведомление модератору при отправке заявки на расход (submit) ---
# Получатель по умолчанию zumerov@kostalegal.com; несколько адресов через запятую.
# Без EXPENSE_SMTP_HOST + USER + PASSWORD письма не уходят (в логах — предупреждение).
# Microsoft 365: включите SMTP AUTH для ящика / app password; сервер smtp.office365.com, порт 587, STARTTLS.
# EXPENSE_NOTIFY_ON_SUBMIT=true
# Получатели, если EXPENSE_NOTIFY_ROUTING_JSON не задан: несколько адресов через запятую.
# EXPENSE_NOTIFY_TO=zumerov@kostalegal.com
#
# Маршрутизация писем (JSON в одну строку). Если задан — используется вместо EXPENSE_NOTIFY_TO
# (кроме fallback при ошибке JSON). См. expenses/infrastructure/expense_notify_routing.py
# Пример: оба ящика на все заявки:
# EXPENSE_NOTIFY_ROUTING_JSON={"default":["zumerov@kostalegal.com","aakhmadjonov@kostalegal.com"]}
# Пример: по подразделению (id как в GET /api/v1/departments) + третий ящик по правилу:
# EXPENSE_NOTIFY_ROUTING_JSON={"default":["zumerov@kostalegal.com"],"rules":[{"if":{"departmentId":"PUT_UUID_HERE"},"to":["aakhmadjonov@kostalegal.com"]},{"if":{"projectId":"PUT_PROJECT_ID"},"to":["third@kostalegal.com"]}]}
# FRONTEND_URL задаётся выше — для ссылки «открыть заявку» в письме (тот же origin, что и CORS).
# Для hash-router SPA: EXPENSE_NOTIFY_LINK_TEMPLATE={frontend_url}/#/expenses/{expense_id}
# EXPENSE_NOTIFY_LINK_TEMPLATE=
# (Редко) intent для фронта — в письме сейчас не используется для согласования; основной путь — email-action по API
# EXPENSE_NOTIFY_INTENT_PARAM=intent
# Письмо автору заявки после утверждения/отклонения (нужны те же SMTP, что и для модераторов)
# EXPENSE_NOTIFY_AUTHOR_ON_DECISION=true
# Для согласования по ссылке из письма (нет Bearer): JWT с правом GET /users/{id} — иначе письмо автору не отправится
# EXPENSE_AUTH_BEARER_FOR_AUTHOR_EMAIL=
# Сброс БД расходов из админки: POST /api/v1/admin/expenses-database/reset (тело {"confirm":"RESET_EXPENSES_DB"}), только «Главный администратор»
# EXPENSE_ALLOW_DATABASE_RESET=true
# EXPENSE_SMTP_HOST=smtp.office365.com
# EXPENSE_SMTP_PORT=587
# EXPENSE_SMTP_USER=noreply@kostalegal.com
# EXPENSE_SMTP_PASSWORD=
# EXPENSE_SMTP_USE_TLS=true
# EXPENSE_MAIL_FROM=noreply@kostalegal.com
ATTENDANCE_SERVICE_URL=http://attendance:1239
#
# Gateway запущен на хосте (uvicorn локально), а auth/attendance — тоже на хосте с портами из Dockerfile:
# AUTH_SERVICE_URL=http://127.0.0.1:1236
# ATTENDANCE_SERVICE_URL=http://127.0.0.1:1239
# EXPENSES_SERVICE_URL=http://127.0.0.1:1242
#
# Только gateway в Docker, остальные процессы на Windows/Mac (Docker Desktop):
# AUTH_SERVICE_URL=http://host.docker.internal:1236
# ATTENDANCE_SERVICE_URL=http://host.docker.internal:1239
# EXPENSES_SERVICE_URL=http://host.docker.internal:1242
# Hikvision: IP камер (одна — HIKVISION_DEVICE_IP, несколько — HIKVISION_DEVICE_IPS через запятую)
HIKVISION_DEVICE_IP=
HIKVISION_DEVICE_IPS=
HIKVISION_DEVICE_PORT=80
HIKVISION_DEVICE_USER=admin
HIKVISION_DEVICE_PASSWORD=
HIKVISION_REQUEST_TIMEOUT=60
# IP камер для gateway (защита от SSRF — должен совпадать с HIKVISION_DEVICE_IP(S))
ATTENDANCE_HIKVISION_ALLOWED_IPS=
# FRONTEND_URL см. блок «Редиректы» выше
# Админ-панель по IP (например http://192.168.230.142:8080): задайте тот же origin — иначе CORS к gateway (:1234) заблокирует вход
ADMIN_FRONTEND_URL=http://localhost:8080
# Если «Bind for 0.0.0.0:8080 failed: port is already allocated» — смените порт (например 8081).
ADMIN_PANEL_PORT=8080
MEDIA_PATH=/app/media

TELEGRAM_BOT_TOKEN=

AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI см. блок «Редиректы» выше
# Обязательно для production: задайте надёжный секрет
JWT_SECRET=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
# По умолчанию в коде auth — 1440 (сутки). Дольше только при явной необходимости.
JWT_EXPIRE_MINUTES=1440

# Gateway: широкий CORS для частных сетей (false в проде + явные FRONTEND_URL).
# CORS_ALLOW_PRIVATE_NETWORK=false
# Одинаковый секрет на gateway, tickets, notifications — внутренние WebSocket только через gateway.
# WS_INTERNAL_SECRET=
# HTTPS за reverse-proxy: SECURITY_HSTS_ENABLED=true

ADMIN_USERNAME=admin
# Локальный вход в админ-панель: до первичной настройки — пара логин/пароль из env.
# После POST /auth/admin-bootstrap пароль хранится в БД; ADMIN_PASSWORD можно не задавать.
ADMIN_PASSWORD=
# Одноразовая первичная настройка на сервере: сгенерировать логин/пароль и записать в БД.
# Вызов: POST /api/v1/auth/admin/bootstrap с JSON {"secret":"<тот же секрет>"}. Потом секрет убрать из .env.
# ADMIN_BOOTSTRAP_SECRET=

# CALENDAR_CONNECTED_REDIRECT_URL и MICROSOFT_REDIRECT_URI см. блок «Редиректы» выше
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
